<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Hyper_Transmit.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Hyper_Transmit"
    xmlns:models="using:Hyper_Transmit.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <Grid RowDefinitions="*,Auto">

        <!-- Dual Panel -->
        <Grid Grid.Row="0" Padding="12,8,12,0" ColumnDefinitions="*,Auto,*">

            <!-- LEFT PANEL: Local Files -->
            <Grid Grid.Column="0" RowDefinitions="Auto,*,Auto">
                <!-- Local Path Bar -->
                <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,*,Auto,Auto" Padding="0,0,0,4">
                    <Button Grid.Column="0" x:Name="LocalUpButton" Width="36" Height="32" Padding="6" Click="LocalUpButton_Click" Margin="0,0,4,0">
                        <FontIcon Glyph="&#xE70E;" FontSize="13"/>
                    </Button>
                    <Button Grid.Column="1" x:Name="LocalDrivesButton" Width="36" Height="32" Padding="6" Click="LocalDrivesButton_Click" Margin="0,0,4,0" ToolTipService.ToolTip="选择磁盘">
                        <FontIcon Glyph="&#xE7F4;" FontSize="13"/>
                    </Button>
                    <TextBox Grid.Column="2" x:Name="LocalPathBox" PlaceholderText="本地路径" KeyDown="LocalPathBox_KeyDown" Margin="0,0,4,0"/>
                    <Button Grid.Column="3" x:Name="LocalRefreshButton" Width="36" Height="32" Padding="6" Click="LocalRefreshButton_Click">
                        <FontIcon Glyph="&#xE72C;" FontSize="13"/>
                    </Button>
                </Grid>

                <!-- Local File List -->
                <ListView Grid.Row="1" x:Name="LocalFileList" SelectionMode="Single"
                    DoubleTapped="LocalFileList_DoubleTapped" SelectionChanged="LocalFileList_SelectionChanged"
                    IsDoubleTapEnabled="True" RightTapped="LocalFileList_RightTapped">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:LocalFileInfo">
                            <Grid ColumnDefinitions="24,*,80,140" Padding="0,2">
                                <FontIcon Grid.Column="0" FontSize="14" Glyph="{x:Bind local:HomePage.GetFileIcon(IsDirectory, Extension), Mode=OneWay}"/>
                                <TextBlock Grid.Column="1" Text="{x:Bind Name}" VerticalAlignment="Center" Margin="4,0" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="2" Text="{x:Bind SizeDisplay}" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBlock Grid.Column="3" Text="{x:Bind local:HomePage.FormatDate(LastModified), Mode=OneWay}" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <FlyoutBase.AttachedFlyout>
                        <MenuFlyout x:Name="LocalContextMenu">
                            <MenuFlyoutItem Text="上传到远程" Click="LocalContextUpload_Click" Icon="Upload"/>
                            <MenuFlyoutSeparator/>
                            <MenuFlyoutItem Text="复制" Click="LocalContextCopy_Click" Icon="Copy"/>
                            <MenuFlyoutItem Text="剪切" Click="LocalContextCut_Click" Icon="Cut"/>
                            <MenuFlyoutItem Text="粘贴" Click="LocalContextPaste_Click" Icon="Paste" x:Name="LocalPasteMenuItem" IsEnabled="False"/>
                            <MenuFlyoutSeparator/>
                            <MenuFlyoutItem Text="重命名" Click="LocalContextRename_Click" Icon="Rename"/>
                            <MenuFlyoutItem Text="删除" Click="LocalContextDelete_Click" Icon="Delete"/>
                            <MenuFlyoutSeparator/>
                            <MenuFlyoutItem Text="新建文件夹" Click="LocalContextNewFolder_Click" Icon="NewFolder"/>
                            <MenuFlyoutItem Text="刷新" Click="LocalRefreshButton_Click" Icon="Refresh"/>
                        </MenuFlyout>
                    </FlyoutBase.AttachedFlyout>
                </ListView>

                <!-- Local Status -->
                <TextBlock Grid.Row="2" x:Name="LocalStatusText" Text="就绪" FontSize="11" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" Padding="0,4,0,0"/>
            </Grid>

            <!-- Center Action Buttons -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="8" Margin="8,0">
                <Button x:Name="UploadButton" ToolTipService.ToolTip="上传到远程" Click="UploadButton_Click" Width="40" Height="40" Padding="0" HorizontalContentAlignment="Center" IsEnabled="False">
                    <FontIcon Glyph="&#xE72A;" FontSize="16"/>
                </Button>
                <Button x:Name="DownloadButton" ToolTipService.ToolTip="下载到本地" Click="DownloadButton_Click" Width="40" Height="40" Padding="0" HorizontalContentAlignment="Center" IsEnabled="False">
                    <FontIcon Glyph="&#xE72B;" FontSize="16"/>
                </Button>
            </StackPanel>

            <!-- RIGHT PANEL -->
            <Grid Grid.Column="2" RowDefinitions="Auto,*,Auto">

                <!-- Remote Path Bar (shown when connected) -->
                <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,*,Auto" Padding="0,0,0,4" x:Name="RemotePathBar" Visibility="Collapsed">
                    <Button Grid.Column="0" x:Name="RemoteUpButton" Width="36" Height="32" Padding="6" Click="RemoteUpButton_Click" Margin="0,0,4,0">
                        <FontIcon Glyph="&#xE70E;" FontSize="13"/>
                    </Button>
                    <TextBox Grid.Column="2" x:Name="RemotePathBox" PlaceholderText="远程路径" KeyDown="RemotePathBox_KeyDown" Margin="0,0,4,0"/>
                    <Button Grid.Column="3" x:Name="RemoteRefreshButton" Width="36" Height="32" Padding="6" Click="RemoteRefreshButton_Click">
                        <FontIcon Glyph="&#xE72C;" FontSize="13"/>
                    </Button>
                </Grid>

                <!-- Remote File List (shown when connected) -->
                <ListView Grid.Row="1" x:Name="RemoteFileList" SelectionMode="Single"
                    DoubleTapped="RemoteFileList_DoubleTapped" SelectionChanged="RemoteFileList_SelectionChanged"
                    IsDoubleTapEnabled="True" RightTapped="RemoteFileList_RightTapped" Visibility="Collapsed">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:RemoteFileInfo">
                            <Grid ColumnDefinitions="24,*,80,140" Padding="0,2">
                                <FontIcon Grid.Column="0" FontSize="14" Glyph="{x:Bind local:HomePage.GetRemoteFileIcon(IsDirectory), Mode=OneWay}"/>
                                <TextBlock Grid.Column="1" Text="{x:Bind Name}" VerticalAlignment="Center" Margin="4,0" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="2" Text="{x:Bind SizeDisplay}" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBlock Grid.Column="3" Text="{x:Bind local:HomePage.FormatDate(LastModified), Mode=OneWay}" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <FlyoutBase.AttachedFlyout>
                        <MenuFlyout x:Name="RemoteContextMenu">
                            <MenuFlyoutItem Text="下载到本地" Click="RemoteContextDownload_Click" Icon="Download"/>
                            <MenuFlyoutSeparator/>
                            <MenuFlyoutItem Text="重命名" Click="RemoteContextRename_Click" Icon="Rename"/>
                            <MenuFlyoutItem Text="删除" Click="RemoteContextDelete_Click" Icon="Delete"/>
                            <MenuFlyoutSeparator/>
                            <MenuFlyoutItem Text="权限..." Click="RemoteContextPermissions_Click" Icon="Permissions"/>
                            <MenuFlyoutSeparator/>
                            <MenuFlyoutItem Text="新建文件夹" Click="RemoteContextNewFolder_Click" Icon="NewFolder"/>
                            <MenuFlyoutItem Text="刷新" Click="RemoteRefreshButton_Click" Icon="Refresh"/>
                        </MenuFlyout>
                    </FlyoutBase.AttachedFlyout>
                </ListView>

                <!-- Connect Form (shown when NOT connected) -->
                <StackPanel Grid.Row="1" x:Name="ConnectPanel" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12" MaxWidth="400" MinWidth="300">
                    <FontIcon Glyph="&#xE71B;" FontSize="48" HorizontalAlignment="Center" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBlock Text="连接到远程服务器" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>

                    <!-- Protocol & Auth Type -->
                    <Grid ColumnDefinitions="*,8,*">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="协议" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                            <ComboBox x:Name="ConnectProtocolCombo" SelectedIndex="0" SelectionChanged="ConnectProtocolCombo_SelectionChanged">
                                <ComboBoxItem Content="SFTP"/>
                                <ComboBoxItem Content="SCP"/>
                                <ComboBoxItem Content="FTP"/>
                                <ComboBoxItem Content="FTPS"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="认证方式" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                            <ComboBox x:Name="ConnectAuthCombo" SelectedIndex="0" SelectionChanged="ConnectAuthCombo_SelectionChanged">
                                <ComboBoxItem Content="密码"/>
                                <ComboBoxItem Content="私钥"/>
                                <ComboBoxItem Content="私钥+密码"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <Grid ColumnDefinitions="*,8,100">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="主机" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                            <TextBox x:Name="ConnectHostBox" PlaceholderText="主机地址或 IP"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="端口" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                            <NumberBox x:Name="ConnectPortBox" Value="22" SpinButtonPlacementMode="Compact"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Spacing="4">
                        <TextBlock Text="用户名" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                        <TextBox x:Name="ConnectUsernameBox" PlaceholderText="用户名"/>
                    </StackPanel>

                    <!-- Password (shown for Password auth) -->
                    <StackPanel x:Name="PasswordSection" Spacing="4">
                        <TextBlock Text="密码" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                        <PasswordBox x:Name="ConnectPasswordBox" PlaceholderText="密码" KeyDown="ConnectPasswordBox_KeyDown"/>
                    </StackPanel>

                    <!-- Private Key (shown for PrivateKey auth) -->
                    <StackPanel x:Name="KeySection" Spacing="4" Visibility="Collapsed">
                        <TextBlock Text="私钥文件" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Grid.Column="0" x:Name="ConnectKeyPathBox" PlaceholderText="私钥文件路径 (.pem)" Margin="0,0,4,0"/>
                            <Button Grid.Column="1" Content="浏览..." Click="ConnectBrowseKeyButton_Click"/>
                        </Grid>
                    </StackPanel>

                    <!-- Key Passphrase (shown for Key auth) -->
                    <StackPanel x:Name="PassphraseSection" Spacing="4" Visibility="Collapsed">
                        <TextBlock Text="私钥密码" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                        <PasswordBox x:Name="ConnectPassphraseBox" PlaceholderText="私钥密码（如无密码可留空）"/>
                    </StackPanel>

                    <Button x:Name="ConnectSubmitButton" Style="{ThemeResource AccentButtonStyle}" Click="ConnectSubmitButton_Click" HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE71B;" FontSize="14"/>
                            <TextBlock Text="连接"/>
                        </StackPanel>
                    </Button>

                    <TextBlock x:Name="ConnectErrorText" FontSize="12" Foreground="Red" TextWrapping="Wrap" HorizontalAlignment="Center" Visibility="Collapsed"/>
                </StackPanel>

                <!-- Disconnect Button (shown when connected) -->
                <StackPanel Grid.Row="1" x:Name="DisconnectOverlay" Visibility="Collapsed" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,0,8">
                    <Button x:Name="DisconnectButton" Click="DisconnectButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xE71A;" FontSize="14"/>
                            <TextBlock Text="断开连接"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Remote Status -->
                <TextBlock Grid.Row="2" x:Name="RemoteStatusText" Text="未连接" FontSize="11" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" Padding="0,4,0,0"/>
            </Grid>
        </Grid>

        <!-- Bottom Status -->
        <TextBlock Grid.Row="1" x:Name="BottomStatusText" Text="" FontSize="11"
                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                   Padding="12,4"/>
    </Grid>
</Page>