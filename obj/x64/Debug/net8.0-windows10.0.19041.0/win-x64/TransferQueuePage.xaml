<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Hyper_Transmit.TransferQueuePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Top Bar: multi-select actions -->
        <StackPanel x:ConnectionId='2' Grid.Row="0" Orientation="Horizontal" Spacing="4" Padding="12,8"
                    x:Name="SelectionActionBar" Visibility="Collapsed">
            <TextBlock x:ConnectionId='11' x:Name="SelectionCountText" Text="已选: 0" VerticalAlignment="Center" 
                       FontSize="13" FontWeight="SemiBold" Margin="0,0,12,0"/>
            <Button x:ConnectionId='12'                              Content="暂停"/>
            <Button x:ConnectionId='13'                               Content="恢复"/>
            <Button x:ConnectionId='14'                               Content="取消"/>
            <Button x:ConnectionId='15'                              Content="移除"/>
            <Button x:ConnectionId='16'                               Content="全选" Margin="8,0,0,0"/>
            <Button x:ConnectionId='17'                                    Content="取消选择"/>
        </StackPanel>

        <!-- Clear completed when no selection -->
        <StackPanel x:ConnectionId='3' Grid.Row="0" Orientation="Horizontal" Spacing="4" Padding="12,8"
                    x:Name="HintPanel">
            <Button x:ConnectionId='10'                                    Content="清除已完成"/>
        </StackPanel>

        <!-- Transfer Items -->
        <ScrollViewer x:ConnectionId='4' Grid.Row="1" Padding="12,0"                             >
            <StackPanel x:ConnectionId='9' x:Name="TransferItems" Spacing="8"/>
        </ScrollViewer>

        <!-- Bottom Summary (text only, no icons) -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="16" Padding="12,6"
                    Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
            <TextBlock x:ConnectionId='5' x:Name="TotalCountText" Text="总计: 0" FontSize="12"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
            <TextBlock x:ConnectionId='6' x:Name="CompletedCountText" Text="已完成: 0" FontSize="12"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
            <TextBlock x:ConnectionId='7' x:Name="PendingCountText" Text="等待中: 0" FontSize="12"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
            <TextBlock x:ConnectionId='8' x:Name="FailedCountText" Text="失败: 0" FontSize="12"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
        </StackPanel>
    </Grid>
</Page>

