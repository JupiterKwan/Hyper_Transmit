<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Hyper_Transmit.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Hyper_Transmit"
    xmlns:models="using:Hyper_Transmit.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <Grid RowDefinitions="*,Auto">

        <!-- Dual Panel -->
        <Grid Grid.Row="0" Padding="12,8,12,0" ColumnDefinitions="*,Auto,*">

            <!-- LEFT PANEL: Local Files -->
            <Grid Grid.Column="0" RowDefinitions="Auto,*,Auto">
                <!-- Local Path Bar -->
                <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,*,Auto,Auto" Padding="0,0,0,4">
                    <Button x:ConnectionId='58' Grid.Column="0" x:Name="LocalUpButton" Width="36" Height="32" Padding="6"                             Margin="0,0,4,0">
                        <FontIcon Glyph="&#xE70E;" FontSize="13"/>
                    </Button>
                    <Button x:ConnectionId='59' Grid.Column="1" x:Name="LocalDrivesButton" Width="36" Height="32" Padding="6"                                 Margin="0,0,4,0" ToolTipService.ToolTip="选择磁盘">
                        <FontIcon Glyph="&#xE7F4;" FontSize="13"/>
                    </Button>
                    <TextBox x:ConnectionId='60' Grid.Column="2" x:Name="LocalPathBox" PlaceholderText="本地路径"                                Margin="0,0,4,0"/>
                    <Button x:ConnectionId='61' Grid.Column="3" x:Name="LocalRefreshButton" Width="36" Height="32" Padding="6"                                 >
                        <FontIcon Glyph="&#xE72C;" FontSize="13"/>
                    </Button>
                </Grid>

                <!-- Local File List -->
                <ListView x:ConnectionId='41' Grid.Row="1" x:Name="LocalFileList" SelectionMode="Single"
                                                                                                               
                    IsDoubleTapEnabled="True"                                        >
                    <ListView.ItemTemplate>
                        <DataTemplate                                  >
                            <Grid x:ConnectionId='44' ColumnDefinitions="24,*,80,140" Padding="0,2">
                                <FontIcon x:ConnectionId='45' Grid.Column="0" FontSize="14"                                                                                 />
                                <TextBlock x:ConnectionId='46' Grid.Column="1"                      VerticalAlignment="Center" Margin="4,0" TextTrimming="CharacterEllipsis"/>
                                <TextBlock x:ConnectionId='47' Grid.Column="2"                             VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBlock x:ConnectionId='48' Grid.Column="3"                                                                      VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <FlyoutBase.AttachedFlyout>
                        <MenuFlyout x:ConnectionId='49' x:Name="LocalContextMenu">
                            <MenuFlyoutItem x:ConnectionId='50' Text="上传到远程"                                  Icon="Upload"/>
                            <MenuFlyoutSeparator/>
                            <MenuFlyoutItem x:ConnectionId='51' Text="复制"                                Icon="Copy"/>
                            <MenuFlyoutItem x:ConnectionId='52' Text="剪切"                               Icon="Cut"/>
                            <MenuFlyoutItem x:ConnectionId='53' Text="粘贴"                                 Icon="Paste" x:Name="LocalPasteMenuItem" IsEnabled="False"/>
                            <MenuFlyoutSeparator/>
                            <MenuFlyoutItem x:ConnectionId='54' Text="重命名"                                  Icon="Rename"/>
                            <MenuFlyoutItem x:ConnectionId='55' Text="删除"                                  Icon="Delete"/>
                            <MenuFlyoutSeparator/>
                            <MenuFlyoutItem x:ConnectionId='56' Text="新建文件夹"                                     Icon="NewFolder"/>
                            <MenuFlyoutItem x:ConnectionId='57' Text="刷新"                                  Icon="Refresh"/>
                        </MenuFlyout>
                    </FlyoutBase.AttachedFlyout>
                </ListView>

                <!-- Local Status -->
                <TextBlock x:ConnectionId='42' Grid.Row="2" x:Name="LocalStatusText" Text="就绪" FontSize="11" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" Padding="0,4,0,0"/>
            </Grid>

            <!-- Center Action Buttons -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="8" Margin="8,0">
                <Button x:ConnectionId='39' x:Name="UploadButton" ToolTipService.ToolTip="上传到远程"                            Width="40" Height="40" Padding="0" HorizontalContentAlignment="Center" IsEnabled="False">
                    <FontIcon Glyph="&#xE72A;" FontSize="16"/>
                </Button>
                <Button x:ConnectionId='40' x:Name="DownloadButton" ToolTipService.ToolTip="下载到本地"                              Width="40" Height="40" Padding="0" HorizontalContentAlignment="Center" IsEnabled="False">
                    <FontIcon Glyph="&#xE72B;" FontSize="16"/>
                </Button>
            </StackPanel>

            <!-- RIGHT PANEL -->
            <Grid Grid.Column="2" RowDefinitions="Auto,*,Auto">

                <!-- Remote Path Bar (shown when connected) -->
                <Grid x:ConnectionId='3' Grid.Row="0" ColumnDefinitions="Auto,Auto,*,Auto" Padding="0,0,0,4" x:Name="RemotePathBar" Visibility="Collapsed">
                    <Button x:ConnectionId='36' Grid.Column="0" x:Name="RemoteUpButton" Width="36" Height="32" Padding="6"                              Margin="0,0,4,0">
                        <FontIcon Glyph="&#xE70E;" FontSize="13"/>
                    </Button>
                    <TextBox x:ConnectionId='37' Grid.Column="2" x:Name="RemotePathBox" PlaceholderText="远程路径"                                 Margin="0,0,4,0"/>
                    <Button x:ConnectionId='38' Grid.Column="3" x:Name="RemoteRefreshButton" Width="36" Height="32" Padding="6"                                  >
                        <FontIcon Glyph="&#xE72C;" FontSize="13"/>
                    </Button>
                </Grid>

                <!-- Remote File List (shown when connected) -->
                <ListView x:ConnectionId='4' Grid.Row="1" x:Name="RemoteFileList" SelectionMode="Single"
                                                                                                                 
                    IsDoubleTapEnabled="True"                                          Visibility="Collapsed">
                    <ListView.ItemTemplate>
                        <DataTemplate                                   >
                            <Grid x:ConnectionId='24' ColumnDefinitions="24,*,80,140" Padding="0,2">
                                <FontIcon x:ConnectionId='25' Grid.Column="0" FontSize="14"                                                                            />
                                <TextBlock x:ConnectionId='26' Grid.Column="1"                      VerticalAlignment="Center" Margin="4,0" TextTrimming="CharacterEllipsis"/>
                                <TextBlock x:ConnectionId='27' Grid.Column="2"                             VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBlock x:ConnectionId='28' Grid.Column="3"                                                                      VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <FlyoutBase.AttachedFlyout>
                        <MenuFlyout x:ConnectionId='29' x:Name="RemoteContextMenu">
                            <MenuFlyoutItem x:ConnectionId='30' Text="下载到本地"                                     Icon="Download"/>
                            <MenuFlyoutSeparator/>
                            <MenuFlyoutItem x:ConnectionId='31' Text="重命名"                                   Icon="Rename"/>
                            <MenuFlyoutItem x:ConnectionId='32' Text="删除"                                   Icon="Delete"/>
                            <MenuFlyoutSeparator/>
                            <MenuFlyoutItem x:ConnectionId='33' Text="权限..."                                        Icon="Permissions"/>
                            <MenuFlyoutSeparator/>
                            <MenuFlyoutItem x:ConnectionId='34' Text="新建文件夹"                                      Icon="NewFolder"/>
                            <MenuFlyoutItem x:ConnectionId='35' Text="刷新"                                   Icon="Refresh"/>
                        </MenuFlyout>
                    </FlyoutBase.AttachedFlyout>
                </ListView>

                <!-- Connect Form (shown when NOT connected) -->
                <StackPanel x:ConnectionId='5' Grid.Row="1" x:Name="ConnectPanel" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12" MaxWidth="400" MinWidth="300">
                    <FontIcon Glyph="&#xE71B;" FontSize="48" HorizontalAlignment="Center" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBlock Text="连接到远程服务器" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>

                    <!-- Protocol & Auth Type -->
                    <Grid ColumnDefinitions="*,8,*">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="协议" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                            <ComboBox x:ConnectionId='22' x:Name="ConnectProtocolCombo" SelectedIndex="0"                                                         >
                                <ComboBoxItem Content="SFTP"/>
                                <ComboBoxItem Content="SCP"/>
                                <ComboBoxItem Content="FTP"/>
                                <ComboBoxItem Content="FTPS"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="认证方式" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                            <ComboBox x:ConnectionId='21' x:Name="ConnectAuthCombo" SelectedIndex="0"                                                     >
                                <ComboBoxItem Content="密码"/>
                                <ComboBoxItem Content="私钥"/>
                                <ComboBoxItem Content="私钥+密码"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <Grid ColumnDefinitions="*,8,100">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="主机" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                            <TextBox x:ConnectionId='20' x:Name="ConnectHostBox" PlaceholderText="主机地址或 IP"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="端口" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                            <NumberBox x:ConnectionId='19' x:Name="ConnectPortBox" Value="22" SpinButtonPlacementMode="Compact"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Spacing="4">
                        <TextBlock Text="用户名" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                        <TextBox x:ConnectionId='18' x:Name="ConnectUsernameBox" PlaceholderText="用户名"/>
                    </StackPanel>

                    <!-- Password (shown for Password auth) -->
                    <StackPanel x:ConnectionId='9' x:Name="PasswordSection" Spacing="4">
                        <TextBlock Text="密码" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                        <PasswordBox x:ConnectionId='17' x:Name="ConnectPasswordBox" PlaceholderText="密码"                                     />
                    </StackPanel>

                    <!-- Private Key (shown for PrivateKey auth) -->
                    <StackPanel x:ConnectionId='10' x:Name="KeySection" Spacing="4" Visibility="Collapsed">
                        <TextBlock Text="私钥文件" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox x:ConnectionId='15' Grid.Column="0" x:Name="ConnectKeyPathBox" PlaceholderText="私钥文件路径 (.pem)" Margin="0,0,4,0"/>
                            <Button x:ConnectionId='16' Grid.Column="1" Content="浏览..."                                     />
                        </Grid>
                    </StackPanel>

                    <!-- Key Passphrase (shown for Key auth) -->
                    <StackPanel x:ConnectionId='11' x:Name="PassphraseSection" Spacing="4" Visibility="Collapsed">
                        <TextBlock Text="私钥密码" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                        <PasswordBox x:ConnectionId='14' x:Name="ConnectPassphraseBox" PlaceholderText="私钥密码（如无密码可留空）"/>
                    </StackPanel>

                    <Button x:ConnectionId='12' x:Name="ConnectSubmitButton" Style="{ThemeResource AccentButtonStyle}"                                   HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE71B;" FontSize="14"/>
                            <TextBlock Text="连接"/>
                        </StackPanel>
                    </Button>

                    <TextBlock x:ConnectionId='13' x:Name="ConnectErrorText" FontSize="12" Foreground="Red" TextWrapping="Wrap" HorizontalAlignment="Center" Visibility="Collapsed"/>
                </StackPanel>

                <!-- Disconnect Button (shown when connected) -->
                <StackPanel x:ConnectionId='6' Grid.Row="1" x:Name="DisconnectOverlay" Visibility="Collapsed" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,0,8">
                    <Button x:ConnectionId='8' x:Name="DisconnectButton"                               >
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xE71A;" FontSize="14"/>
                            <TextBlock Text="断开连接"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Remote Status -->
                <TextBlock x:ConnectionId='7' Grid.Row="2" x:Name="RemoteStatusText" Text="未连接" FontSize="11" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" Padding="0,4,0,0"/>
            </Grid>
        </Grid>

        <!-- Bottom Status -->
        <TextBlock x:ConnectionId='2' Grid.Row="1" x:Name="BottomStatusText" Text="" FontSize="11"
                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                   Padding="12,4"/>
    </Grid>
</Page>

