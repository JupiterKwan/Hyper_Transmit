<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Hyper_Transmit.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Hyper_Transmit"
    xmlns:models="using:Hyper_Transmit.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <Grid ColumnDefinitions="200,*">
        <!-- Settings Navigation -->
        <ListView x:ConnectionId='2'
            Grid.Column="0"
            x:Name="SettingsNav"
                                                           
            SelectionMode="Single"
            Padding="8">
            <ListViewItem Tag="General" IsSelected="True">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE713;" FontSize="16"/>
                    <TextBlock Text="常规"/>
                </StackPanel>
            </ListViewItem>
            <ListViewItem Tag="Transfer">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE898;" FontSize="16"/>
                    <TextBlock Text="传输"/>
                </StackPanel>
            </ListViewItem>
            <ListViewItem Tag="Appearance">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE771;" FontSize="16"/>
                    <TextBlock Text="外观"/>
                </StackPanel>
            </ListViewItem>
            <ListViewItem Tag="Logging">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE7BA;" FontSize="16"/>
                    <TextBlock Text="日志"/>
                </StackPanel>
            </ListViewItem>
        </ListView>

        <!-- Settings Content -->
        <ScrollViewer Grid.Column="1" Padding="20,8">
            <StackPanel x:ConnectionId='3' x:Name="ContentPanel">
            <!-- General Settings -->
            <StackPanel x:ConnectionId='4' x:Name="GeneralPanel" Spacing="16" MaxWidth="500" Visibility="Visible">
                <TextBlock Text="常规设置" Style="{ThemeResource SubtitleTextBlockStyle}" Margin="0,0,0,8"/>

                <StackPanel Spacing="4">
                    <TextBlock Text="并行传输数" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <ComboBox x:ConnectionId='23' x:Name="ConcurrentTransfersCombo" SelectedIndex="2" Width="120"
                                                                                          >
                        <ComboBoxItem Content="1"/>
                        <ComboBoxItem Content="2"/>
                        <ComboBoxItem Content="3"/>
                        <ComboBoxItem Content="5"/>
                        <ComboBoxItem Content="10"/>
                    </ComboBox>
                </StackPanel>

                <ToggleSwitch x:ConnectionId='21'
                    x:Name="MinimizeToTraySwitch"
                    Header="关闭时最小化到系统托盘"
                                             />

                <Button x:ConnectionId='22' x:Name="ResetButton" Content="恢复默认设置"                           Margin="0,16,0,0"/>
            </StackPanel>

            <!-- Transfer Settings -->
            <StackPanel x:ConnectionId='5' x:Name="TransferPanel" Spacing="16" MaxWidth="500" Visibility="Collapsed">
                <TextBlock Text="传输设置" Style="{ThemeResource SubtitleTextBlockStyle}" Margin="0,0,0,8"/>

                <ToggleSwitch x:ConnectionId='16'
                    x:Name="RetryOnFailureSwitch"
                    Header="传输失败时自动重试"
                                             />

                <StackPanel Spacing="4">
                    <TextBlock Text="最大重试次数" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <NumberBox x:ConnectionId='20' x:Name="MaxRetriesBox" Value="3" Width="120" SpinButtonPlacementMode="Compact"
                                                                        />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="覆盖规则" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <ComboBox x:ConnectionId='19' x:Name="OverwriteActionCombo" SelectedIndex="0" Width="200"
                                                                                      >
                        <ComboBoxItem Content="询问"/>
                        <ComboBoxItem Content="覆盖"/>
                        <ComboBoxItem Content="跳过"/>
                        <ComboBoxItem Content="重命名"/>
                    </ComboBox>
                </StackPanel>

                <ToggleSwitch x:ConnectionId='17'
                    x:Name="SoundOnCompleteSwitch"
                    Header="传输完成时播放提示音"
                                             />

                <ToggleSwitch x:ConnectionId='18'
                    x:Name="LogTransferHistorySwitch"
                    Header="记录传输历史"
                                             />
            </StackPanel>

            <!-- Appearance Settings -->
            <StackPanel x:ConnectionId='6' x:Name="AppearancePanel" Spacing="16" MaxWidth="500" Visibility="Collapsed">
                <TextBlock Text="外观设置" Style="{ThemeResource SubtitleTextBlockStyle}" Margin="0,0,0,8"/>

                <StackPanel Spacing="4">
                    <TextBlock Text="主题" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <ComboBox x:ConnectionId='15' x:Name="ThemeCombo" SelectedIndex="0" Width="200"
                                                                            >
                        <ComboBoxItem Content="跟随系统"/>
                        <ComboBoxItem Content="浅色"/>
                        <ComboBoxItem Content="深色"/>
                    </ComboBox>
                </StackPanel>

                <ToggleSwitch x:ConnectionId='13'
                    x:Name="ShowHiddenFilesSwitch"
                    Header="显示隐藏文件"
                                             />

                <StackPanel Spacing="4">
                    <TextBlock Text="日期格式" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <ComboBox x:ConnectionId='14' x:Name="DateFormatCombo" SelectedIndex="0" Width="200"
                                                                                 >
                        <ComboBoxItem Content="yyyy-MM-dd HH:mm"/>
                        <ComboBoxItem Content="dd/MM/yyyy HH:mm"/>
                        <ComboBoxItem Content="MM/dd/yyyy hh:mm tt"/>
                        <ComboBoxItem Content="yyyy年MM月dd日 HH:mm"/>
                    </ComboBox>
                </StackPanel>
            </StackPanel>

            <!-- Logging Settings -->
            <StackPanel x:ConnectionId='7' x:Name="LoggingPanel" Spacing="16" MaxWidth="500" Visibility="Collapsed">
                <TextBlock Text="日志设置" Style="{ThemeResource SubtitleTextBlockStyle}" Margin="0,0,0,8"/>

                <ToggleSwitch x:ConnectionId='8'
                    x:Name="EnableLoggingSwitch"
                    Header="启用日志记录"
                                             />

                <StackPanel Spacing="4">
                    <TextBlock Text="日志级别" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <ComboBox x:ConnectionId='12' x:Name="LogLevelCombo" SelectedIndex="1" Width="200"
                                                                               >
                        <ComboBoxItem Content="Verbose"/>
                        <ComboBoxItem Content="Debug"/>
                        <ComboBoxItem Content="Information"/>
                        <ComboBoxItem Content="Warning"/>
                        <ComboBoxItem Content="Error"/>
                    </ComboBox>
                </StackPanel>

                <TextBlock
                    Text="日志文件位置:"
                    FontSize="12"
                    Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                <TextBlock x:ConnectionId='9'
                    x:Name="LogPathText"
                    FontSize="11"
                    Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                    TextWrapping="Wrap"
                    IsTextSelectionEnabled="True"/>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:ConnectionId='10' Content="打开日志文件夹"                            />
                    <Button x:ConnectionId='11' Content="清除日志"                       />
                </StackPanel>
            </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

