<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Hyper_Transmit.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Hyper_Transmit"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Hyper Transmit">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.Resources>
            <CornerRadius x:Key="NavigationViewContentPresenterCornerRadius">0</CornerRadius>
            <CornerRadius x:Key="NavigationViewContentGridCornerRadius">0</CornerRadius>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Main NavigationView -->
        <NavigationView x:ConnectionId='2'
            x:Name="MainNavView"
            Grid.Row="0"
                                                              
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="True"
            CornerRadius="0">

            <NavigationView.MenuItems>
                <NavigationViewItem
                    Content="连接"
                    Tag="HomePage"
                    IsSelected="True">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE71B;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    Content="管理"
                    Tag="ConnectionManagerPage">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8F1;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    Content="队列"
                    Tag="TransferQueuePage">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE768;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <!-- Content Frame -->
            <Frame x:ConnectionId='7' x:Name="ContentFrame" CornerRadius="0"/>
        </NavigationView>

        <!-- Status Bar -->
        <Grid
            Grid.Row="1"
            Padding="12,4"
            Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
            ColumnDefinitions="*,Auto">

            <!-- Status Message -->
            <TextBlock x:ConnectionId='5'
                Grid.Column="0"
                x:Name="StatusText"
                Text="就绪"
                VerticalAlignment="Center"
                FontSize="12"
                Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                TextTrimming="CharacterEllipsis"/>

            <!-- Speed -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" Margin="12,0" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE709;" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                <TextBlock x:ConnectionId='6' x:Name="SpeedText" Text="--" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" MinWidth="60"/>
            </StackPanel>
        </Grid>

        <!-- Floating Notification Overlay (top-right) -->
        <ItemsControl x:ConnectionId='3'
            x:Name="NotificationOverlay"
            Grid.Row="0"
            IsHitTestVisible="False"
            VerticalAlignment="Top"
            HorizontalAlignment="Right"
            Margin="0,8,8,0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Spacing="4"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}" CornerRadius="4" Padding="0">
                        <InfoBar
                            Severity="{Binding Severity}"
                            Title="{Binding Title}"
                            Message="{Binding Message}"
                            IsOpen="True"
                            IsClosable="True"
                            MaxWidth="400"
                            Opacity="1.0"
                            IsHitTestVisible="True"/>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Window>

