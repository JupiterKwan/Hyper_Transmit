<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Hyper_Transmit.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Hyper_Transmit"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Hyper Transmit">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid RowDefinitions="*,Auto">
        <!-- Main NavigationView -->
        <NavigationView x:ConnectionId='2'
            x:Name="MainNavView"
            Grid.Row="0"
                                                              
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="True">

            <NavigationView.MenuItems>
                <NavigationViewItem
                    Icon="Home"
                    Content="快速连接"
                    Tag="HomePage"
                    IsSelected="True"/>
                <NavigationViewItem
                    Icon="Library"
                    Content="连接管理器"
                    Tag="ConnectionManagerPage"/>
                <NavigationViewItem
                    Icon="Sync"
                    Content="传输队列"
                    Tag="TransferQueuePage"/>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <!-- Favorites section in footer could go here -->
            </NavigationView.FooterMenuItems>

            <!-- Content Frame -->
            <Frame x:ConnectionId='8' x:Name="ContentFrame"/>
        </NavigationView>

        <!-- Status Bar -->
        <Grid
            Grid.Row="1"
            Padding="12,4"
            Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
            ColumnDefinitions="*,Auto,Auto,Auto,Auto">

            <!-- Status Message -->
            <TextBlock x:ConnectionId='3'
                Grid.Column="0"
                x:Name="StatusText"
                Text="就绪"
                VerticalAlignment="Center"
                FontSize="12"
                Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                TextTrimming="CharacterEllipsis"/>

            <!-- Active Connections -->
            <StackPanel
                Grid.Column="1"
                Orientation="Horizontal"
                Spacing="4"
                Margin="16,0"
                VerticalAlignment="Center">
                <FontIcon Glyph="&#xE71B;" FontSize="12"
                          Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                <TextBlock x:ConnectionId='7'
                    x:Name="ConnectionStatusText"
                    Text="未连接"
                    FontSize="12"
                    Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
            </StackPanel>

            <!-- Transfer Queue Count -->
            <StackPanel
                Grid.Column="2"
                Orientation="Horizontal"
                Spacing="4"
                Margin="0,0"
                VerticalAlignment="Center">
                <FontIcon Glyph="&#xE8F1;" FontSize="12"
                          Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                <TextBlock x:ConnectionId='6'
                    x:Name="QueueCountText"
                    Text="队列: 0"
                    FontSize="12"
                    Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
            </StackPanel>

            <!-- Active Transfers -->
            <StackPanel
                Grid.Column="3"
                Orientation="Horizontal"
                Spacing="4"
                Margin="16,0"
                VerticalAlignment="Center">
                <FontIcon Glyph="&#xE768;" FontSize="12"
                          Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                <TextBlock x:ConnectionId='5'
                    x:Name="ActiveTransferText"
                    Text="传输: 0"
                    FontSize="12"
                    Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
            </StackPanel>

            <!-- Transfer Speed -->
            <StackPanel
                Grid.Column="4"
                Orientation="Horizontal"
                Spacing="4"
                Margin="0,0"
                VerticalAlignment="Center">
                <FontIcon Glyph="&#xE709;" FontSize="12"
                          Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                <TextBlock x:ConnectionId='4'
                    x:Name="SpeedText"
                    Text="--"
                    FontSize="12"
                    Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                    MinWidth="60"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>

