<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Hyper_Transmit.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Hyper_Transmit"
    xmlns:models="using:Hyper_Transmit.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <Grid ColumnDefinitions="200,*">
        <!-- Settings Navigation -->
        <ListView x:ConnectionId='2'
            Grid.Column="0"
            x:Name="SettingsNav"
                                                           
            SelectionMode="Single"
            Padding="8">
            <ListViewItem Content="⚙ 常规" Tag="General" IsSelected="True"/>
            <ListViewItem Content="📁 传输" Tag="Transfer"/>
            <ListViewItem Content="🎨 外观" Tag="Appearance"/>
            <ListViewItem Content="📝 日志" Tag="Logging"/>
        </ListView>

        <!-- Settings Content -->
        <ScrollViewer Grid.Column="1" Padding="20,8">
            <Grid>
            <!-- General Settings -->
            <StackPanel x:ConnectionId='3' x:Name="GeneralPanel" Spacing="16" MaxWidth="500" Visibility="Visible">
                <TextBlock Text="常规设置" Style="{ThemeResource SubtitleTextBlockStyle}" Margin="0,0,0,8"/>

                <ToggleSwitch x:ConnectionId='24'
                    x:Name="RestoreSessionSwitch"
                    Header="启动时恢复上次会话"
                    IsOn="True"/>

                <StackPanel Spacing="4">
                    <TextBlock Text="默认协议" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <ComboBox x:ConnectionId='29' x:Name="DefaultProtocolCombo" SelectedIndex="0" Width="200">
                        <ComboBoxItem Content="SFTP"/>
                        <ComboBoxItem Content="SCP"/>
                        <ComboBoxItem Content="FTP"/>
                        <ComboBoxItem Content="FTPS"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="默认端口" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <NumberBox x:ConnectionId='28' x:Name="DefaultPortBox" Value="22" Width="120" SpinButtonPlacementMode="Compact"/>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="并行传输数" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <ComboBox x:ConnectionId='27' x:Name="ConcurrentTransfersCombo" SelectedIndex="0" Width="120">
                        <ComboBoxItem Content="1"/>
                        <ComboBoxItem Content="2"/>
                        <ComboBoxItem Content="3"/>
                        <ComboBoxItem Content="5"/>
                        <ComboBoxItem Content="10"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="传输缓冲区 (KB)" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <ComboBox x:ConnectionId='26' x:Name="BufferSizeCombo" SelectedIndex="1" Width="120">
                        <ComboBoxItem Content="8"/>
                        <ComboBoxItem Content="32"/>
                        <ComboBoxItem Content="64"/>
                        <ComboBoxItem Content="128"/>
                        <ComboBoxItem Content="256"/>
                    </ComboBox>
                </StackPanel>

                <ToggleSwitch x:ConnectionId='25'
                    x:Name="MinimizeToTraySwitch"
                    Header="关闭时最小化到系统托盘"
                    IsOn="False"/>
            </StackPanel>

            <!-- Transfer Settings -->
            <StackPanel x:ConnectionId='4' x:Name="TransferPanel" Spacing="16" MaxWidth="500" Visibility="Collapsed">
                <TextBlock Text="传输设置" Style="{ThemeResource SubtitleTextBlockStyle}" Margin="0,0,0,8"/>

                <ToggleSwitch x:ConnectionId='18'
                    x:Name="EnableResumeSwitch"
                    Header="断点续传"
                    IsOn="True"/>

                <ToggleSwitch x:ConnectionId='19'
                    x:Name="RetryOnFailureSwitch"
                    Header="传输失败时自动重试"
                    IsOn="True"/>

                <StackPanel Spacing="4">
                    <TextBlock Text="最大重试次数" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <NumberBox x:ConnectionId='23' x:Name="MaxRetriesBox" Value="3" Width="120" SpinButtonPlacementMode="Compact"/>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="覆盖规则" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <ComboBox x:ConnectionId='22' x:Name="OverwriteActionCombo" SelectedIndex="0" Width="200">
                        <ComboBoxItem Content="询问"/>
                        <ComboBoxItem Content="覆盖"/>
                        <ComboBoxItem Content="跳过"/>
                        <ComboBoxItem Content="重命名"/>
                    </ComboBox>
                </StackPanel>

                <ToggleSwitch x:ConnectionId='20'
                    x:Name="SoundOnCompleteSwitch"
                    Header="传输完成时播放提示音"
                    IsOn="True"/>

                <ToggleSwitch x:ConnectionId='21'
                    x:Name="LogTransferHistorySwitch"
                    Header="记录传输历史"
                    IsOn="True"/>
            </StackPanel>

            <!-- Appearance Settings -->
            <StackPanel x:ConnectionId='5' x:Name="AppearancePanel" Spacing="16" MaxWidth="500" Visibility="Collapsed">
                <TextBlock Text="外观设置" Style="{ThemeResource SubtitleTextBlockStyle}" Margin="0,0,0,8"/>

                <StackPanel Spacing="4">
                    <TextBlock Text="主题" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <ComboBox x:ConnectionId='17' x:Name="ThemeCombo" SelectedIndex="0" Width="200"
                                                                            >
                        <ComboBoxItem Content="跟随系统"/>
                        <ComboBoxItem Content="浅色"/>
                        <ComboBoxItem Content="深色"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="文件列表字体大小" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <Slider x:ConnectionId='16' x:Name="FontSizeSlider" Minimum="10" Maximum="18" Value="13" StepFrequency="1" Width="200"/>
                </StackPanel>

                <ToggleSwitch x:ConnectionId='14'
                    x:Name="ShowHiddenFilesSwitch"
                    Header="显示隐藏文件"
                    IsOn="False"/>

                <StackPanel Spacing="4">
                    <TextBlock Text="日期格式" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <ComboBox x:ConnectionId='15' x:Name="DateFormatCombo" SelectedIndex="0" Width="200">
                        <ComboBoxItem Content="yyyy-MM-dd HH:mm"/>
                        <ComboBoxItem Content="dd/MM/yyyy HH:mm"/>
                        <ComboBoxItem Content="MM/dd/yyyy hh:mm tt"/>
                        <ComboBoxItem Content="yyyy年MM月dd日 HH:mm"/>
                    </ComboBox>
                </StackPanel>
            </StackPanel>

            <!-- Logging Settings -->
            <StackPanel x:ConnectionId='6' x:Name="LoggingPanel" Spacing="16" MaxWidth="500" Visibility="Collapsed">
                <TextBlock Text="日志设置" Style="{ThemeResource SubtitleTextBlockStyle}" Margin="0,0,0,8"/>

                <TextBlock
                    Text="日志文件位置: %LocalAppData%\HyperTransmit\logs\"
                    FontSize="12"
                    Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                    TextWrapping="Wrap"/>

                <ToggleSwitch x:ConnectionId='10'
                    x:Name="EnableLoggingSwitch"
                    Header="启用日志记录"
                    IsOn="True"/>

                <StackPanel Spacing="4">
                    <TextBlock Text="日志级别" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <ComboBox x:ConnectionId='13' x:Name="LogLevelCombo" SelectedIndex="1" Width="200">
                        <ComboBoxItem Content="Verbose"/>
                        <ComboBoxItem Content="Debug"/>
                        <ComboBoxItem Content="Information"/>
                        <ComboBoxItem Content="Warning"/>
                        <ComboBoxItem Content="Error"/>
                    </ComboBox>
                </StackPanel>

                <Button x:ConnectionId='11' Content="打开日志文件夹"                            />
                <Button x:ConnectionId='12' Content="清除日志"                       />
            </StackPanel>

            <!-- Save/Reset Buttons -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,24,0,0">
                <Button x:ConnectionId='8' x:Name="SaveButton" Content="保存设置" Style="{ThemeResource AccentButtonStyle}"                         />
                <Button x:ConnectionId='9' x:Name="ResetButton" Content="恢复默认"                          />
            </StackPanel>

            <TextBlock x:ConnectionId='7' x:Name="StatusText" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" Margin="0,8,0,0"/>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>

