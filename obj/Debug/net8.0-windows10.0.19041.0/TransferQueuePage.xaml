<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Hyper_Transmit.TransferQueuePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Hyper_Transmit"
    xmlns:models="using:Hyper_Transmit.Models"
    xmlns:enums="using:Hyper_Transmit.Models.Enums"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Toolbar -->
        <Grid Grid.Row="0" Padding="12,8" ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto">
            <Button x:ConnectionId='19' Grid.Column="0" x:Name="PauseAllButton" Content="⏸ 全部暂停"                              Margin="0,0,4,0"/>
            <Button x:ConnectionId='20' Grid.Column="1" x:Name="ResumeAllButton" Content="▶ 全部恢复"                               Margin="0,0,4,0"/>
            <Button x:ConnectionId='21' Grid.Column="2" x:Name="CancelAllButton" Content="❌ 取消全部"                               Margin="0,0,4,0"/>
            <Button x:ConnectionId='22' Grid.Column="3" x:Name="ClearCompletedButton" Content="🗑 清除已完成"                                    Margin="0,0,4,0"/>

            <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock x:ConnectionId='23' x:Name="ActiveCountText" Text="活跃: 0" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                <TextBlock Text="|" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
                <TextBlock x:ConnectionId='24' x:Name="OverallSpeedText" Text="--" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
            </StackPanel>
        </Grid>

        <!-- Transfer List -->
        <ListView x:ConnectionId='2'
            Grid.Row="1"
            x:Name="TransferList"
            SelectionMode="Single"
            Padding="12,0">
            <ListView.ItemTemplate>
                <DataTemplate                                 >
                    <Grid x:ConnectionId='8' Padding="8,6" ColumnDefinitions="28,*,100,200,80,80" RowDefinitions="Auto,Auto">
                        <!-- Status Icon -->
                        <FontIcon x:ConnectionId='9'
                            Grid.Column="0" Grid.RowSpan="2"
                                                                                                       
                            FontSize="16"
                                                                                                             
                            VerticalAlignment="Center"/>

                        <!-- File Name & Direction -->
                        <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal" Spacing="8">
                            <TextBlock x:ConnectionId='16'                          FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock x:ConnectionId='17'                                  FontSize="11"
                                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:ConnectionId='18'                                FontSize="11"
                                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Size -->
                        <TextBlock x:ConnectionId='10'
                            Grid.Column="2" Grid.Row="0"
                                                            
                            FontSize="12"
                            Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"/>

                        <!-- Progress Bar -->
                        <ProgressBar x:ConnectionId='11'
                            Grid.Column="3" Grid.Row="0"
                                                                         
                            Maximum="100"
                            Height="16"
                            Margin="8,0"
                            VerticalAlignment="Center"/>

                        <!-- Speed -->
                        <TextBlock x:ConnectionId='12'
                            Grid.Column="4" Grid.Row="0"
                                                        
                            FontSize="12"
                            Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"/>

                        <!-- ETA -->
                        <TextBlock x:ConnectionId='13'
                            Grid.Column="5" Grid.Row="0"
                                                      
                            FontSize="12"
                            Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"/>

                        <!-- Progress Text (second row) -->
                        <TextBlock x:ConnectionId='14'
                            Grid.Column="1" Grid.Row="1"
                                                                                                                                    
                            FontSize="11"
                            Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                            Margin="0,2,0,0"/>

                        <!-- Error Message -->
                        <TextBlock x:ConnectionId='15'
                            Grid.Column="2" Grid.Row="1" Grid.ColumnSpan="4"
                                                        
                            FontSize="11"
                            Foreground="{ThemeResource SystemControlFillColorCriticalBrush}"
                                                                                                             
                            Margin="0,2,0,0"
                            TextTrimming="CharacterEllipsis"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Statistics Bar -->
        <Grid Grid.Row="2" Padding="12,6" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock x:ConnectionId='3' x:Name="TotalCountText" Text="总计: 0" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                <TextBlock x:ConnectionId='4' x:Name="CompletedCountText" Text="已完成: 0" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                <TextBlock x:ConnectionId='5' x:Name="PendingCountText" Text="等待中: 0" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                <TextBlock x:ConnectionId='6' x:Name="FailedCountText" Text="失败: 0" FontSize="12" Foreground="{ThemeResource SystemControlFillColorCriticalBrush}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>

