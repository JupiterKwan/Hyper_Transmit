<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Hyper_Transmit.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Hyper_Transmit"
    xmlns:models="using:Hyper_Transmit.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Quick Connect Bar -->
        <Grid Grid.Row="0" Padding="12,8" ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto">
            <ComboBox x:ConnectionId='41'
                Grid.Column="0"
                x:Name="ProtocolCombo"
                SelectedIndex="0"
                Width="90"
                Margin="0,0,4,0">
                <ComboBoxItem Content="SFTP"/>
                <ComboBoxItem Content="SCP"/>
                <ComboBoxItem Content="FTP"/>
                <ComboBoxItem Content="FTPS"/>
            </ComboBox>

            <TextBox x:ConnectionId='42'
                Grid.Column="1"
                x:Name="HostBox"
                PlaceholderText="主机地址"
                Width="200"
                Margin="0,0,4,0"
                                         />

            <NumberBox x:ConnectionId='43'
                Grid.Column="2"
                x:Name="PortBox"
                Value="22"
                PlaceholderText="端口"
                Width="70"
                SpinButtonPlacementMode="Compact"
                Margin="0,0,4,0"/>

            <TextBox x:ConnectionId='44'
                Grid.Column="3"
                x:Name="UsernameBox"
                PlaceholderText="用户名"
                Margin="0,0,4,0"/>

            <PasswordBox x:ConnectionId='45'
                Grid.Column="4"
                x:Name="PasswordBox"
                PlaceholderText="密码"
                Width="150"
                Margin="0,0,4,0"
                                             />

            <Button x:ConnectionId='46'
                Grid.Column="5"
                x:Name="ConnectButton"
                Content="连接"
                Style="{ThemeResource AccentButtonStyle}"
                                           
                Margin="0,0,4,0"/>

            <Button x:ConnectionId='47'
                Grid.Column="6"
                x:Name="DisconnectButton"
                Content="断开"
                                              
                IsEnabled="False"/>
        </Grid>

        <!-- Error Bar -->
        <InfoBar x:ConnectionId='2'
            Grid.Row="1"
            x:Name="ErrorBar"
            IsOpen="False"
            Severity="Error"
            IsClosable="True"
            Margin="12,0,12,4"/>

        <!-- Dual Panel File Browser -->
        <Grid Grid.Row="2" Padding="12,0,12,8" ColumnDefinitions="*,Auto,*">

            <!-- LEFT PANEL: Local Files -->
            <Grid Grid.Column="0" RowDefinitions="Auto,*,Auto">
                <!-- Local Path Bar -->
                <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,*,Auto" Padding="0,0,0,4">
                    <Button x:ConnectionId='38'
                        Grid.Column="0"
                        x:Name="LocalUpButton"
                        Content="▲"
                        Padding="6,2"
                        FontSize="12"
                                                   
                        Margin="0,0,4,0"/>
                    <FontIcon
                        Grid.Column="1"
                        Glyph="&#xE8B7;"
                        FontSize="14"
                        VerticalAlignment="Center"
                        Margin="0,0,4,0"/>
                    <TextBox x:ConnectionId='39'
                        Grid.Column="2"
                        x:Name="LocalPathBox"
                        PlaceholderText="本地路径"
                                                      
                        Margin="0,0,4,0"/>
                    <Button x:ConnectionId='40'
                        Grid.Column="3"
                        x:Name="LocalRefreshButton"
                        Content="⟳"
                        Padding="6,2"
                        FontSize="12"
                                                        />
                </Grid>

                <!-- Local File List -->
                <ListView x:ConnectionId='24'
                    Grid.Row="1"
                    x:Name="LocalFileList"
                    SelectionMode="Single"
                                                             
                                                                     
                    IsDoubleTapEnabled="True"
                                                           >
                    <ListView.ItemTemplate>
                        <DataTemplate                                  >
                            <Grid x:ConnectionId='27' ColumnDefinitions="24,*,80,140" Padding="0,2">
                                <FontIcon x:ConnectionId='28'
                                    Grid.Column="0"
                                    FontSize="14"
                                                                                                                    />
                                <TextBlock x:ConnectionId='29'
                                    Grid.Column="1"
                                                        
                                    VerticalAlignment="Center"
                                    Margin="4,0"
                                    TextTrimming="CharacterEllipsis"/>
                                <TextBlock x:ConnectionId='30'
                                    Grid.Column="2"
                                                               
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right"
                                    FontSize="12"
                                    Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBlock x:ConnectionId='31'
                                    Grid.Column="3"
                                                                                                        
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right"
                                    FontSize="12"
                                    Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <FlyoutBase.AttachedFlyout>
                        <MenuFlyout x:ConnectionId='32' x:Name="LocalContextMenu">
                            <MenuFlyoutItem x:ConnectionId='33' Text="上传到远程"                                  Icon="Upload"/>
                            <MenuFlyoutSeparator/>
                            <MenuFlyoutItem x:ConnectionId='34' Text="重命名"                                  Icon="Rename"/>
                            <MenuFlyoutItem x:ConnectionId='35' Text="删除"                                  Icon="Delete"/>
                            <MenuFlyoutSeparator/>
                            <MenuFlyoutItem x:ConnectionId='36' Text="新建文件夹"                                     Icon="NewFolder"/>
                            <MenuFlyoutItem x:ConnectionId='37' Text="刷新"                                  Icon="Refresh"/>
                        </MenuFlyout>
                    </FlyoutBase.AttachedFlyout>
                </ListView>

                <!-- Local Status -->
                <TextBlock x:ConnectionId='25'
                    Grid.Row="2"
                    x:Name="LocalStatusText"
                    Text="就绪"
                    FontSize="11"
                    Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                    Padding="0,4,0,0"/>
            </Grid>

            <!-- Center Action Buttons -->
            <StackPanel
                Grid.Column="1"
                VerticalAlignment="Center"
                Spacing="8"
                Margin="8,0">
                <Button x:ConnectionId='21'
                    x:Name="UploadButton"
                    Content="▶"
                    ToolTipService.ToolTip="上传到远程"
                                              
                    Width="40"
                    Padding="0"
                    HorizontalContentAlignment="Center"
                    IsEnabled="False"/>
                <Button x:ConnectionId='22'
                    x:Name="DownloadButton"
                    Content="◀"
                    ToolTipService.ToolTip="下载到本地"
                                                
                    Width="40"
                    Padding="0"
                    HorizontalContentAlignment="Center"
                    IsEnabled="False"/>
                <Button x:ConnectionId='23'
                    x:Name="SyncButton"
                    Content="≫"
                    ToolTipService.ToolTip="同步目录"
                    Width="40"
                    Padding="0"
                    HorizontalContentAlignment="Center"
                    IsEnabled="False"/>
            </StackPanel>

            <!-- RIGHT PANEL: Remote Files -->
            <Grid Grid.Column="2" RowDefinitions="Auto,*,Auto">
                <!-- Remote Path Bar -->
                <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,*,Auto" Padding="0,0,0,4">
                    <Button x:ConnectionId='18'
                        Grid.Column="0"
                        x:Name="RemoteUpButton"
                        Content="▲"
                        Padding="6,2"
                        FontSize="12"
                                                    
                        IsEnabled="False"
                        Margin="0,0,4,0"/>
                    <FontIcon
                        Grid.Column="1"
                        Glyph="&#xE8F4;"
                        FontSize="14"
                        VerticalAlignment="Center"
                        Margin="0,0,4,0"/>
                    <TextBox x:ConnectionId='19'
                        Grid.Column="2"
                        x:Name="RemotePathBox"
                        PlaceholderText="远程路径"
                                                       
                        IsEnabled="False"
                        Margin="0,0,4,0"/>
                    <Button x:ConnectionId='20'
                        Grid.Column="3"
                        x:Name="RemoteRefreshButton"
                        Content="⟳"
                        Padding="6,2"
                        FontSize="12"
                                                         
                        IsEnabled="False"/>
                </Grid>

                <!-- Remote File List -->
                <ListView x:ConnectionId='3'
                    Grid.Row="1"
                    x:Name="RemoteFileList"
                    SelectionMode="Single"
                                                              
                                                                      
                    IsDoubleTapEnabled="True"
                                                            >
                    <ListView.ItemTemplate>
                        <DataTemplate                                   >
                            <Grid x:ConnectionId='6' ColumnDefinitions="24,*,80,140" Padding="0,2">
                                <FontIcon x:ConnectionId='7'
                                    Grid.Column="0"
                                    FontSize="14"
                                                                                                               />
                                <TextBlock x:ConnectionId='8'
                                    Grid.Column="1"
                                                        
                                    VerticalAlignment="Center"
                                    Margin="4,0"
                                    TextTrimming="CharacterEllipsis"/>
                                <TextBlock x:ConnectionId='9'
                                    Grid.Column="2"
                                                               
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right"
                                    FontSize="12"
                                    Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBlock x:ConnectionId='10'
                                    Grid.Column="3"
                                                                                                        
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right"
                                    FontSize="12"
                                    Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <FlyoutBase.AttachedFlyout>
                        <MenuFlyout x:ConnectionId='11' x:Name="RemoteContextMenu">
                            <MenuFlyoutItem x:ConnectionId='12' Text="下载到本地"                                     Icon="Download"/>
                            <MenuFlyoutSeparator/>
                            <MenuFlyoutItem x:ConnectionId='13' Text="重命名"                                   Icon="Rename"/>
                            <MenuFlyoutItem x:ConnectionId='14' Text="删除"                                   Icon="Delete"/>
                            <MenuFlyoutSeparator/>
                            <MenuFlyoutItem x:ConnectionId='15' Text="权限..."                                        Icon="Permissions"/>
                            <MenuFlyoutSeparator/>
                            <MenuFlyoutItem x:ConnectionId='16' Text="新建文件夹"                                      Icon="NewFolder"/>
                            <MenuFlyoutItem x:ConnectionId='17' Text="刷新"                                   Icon="Refresh"/>
                        </MenuFlyout>
                    </FlyoutBase.AttachedFlyout>
                </ListView>

                <!-- Remote Status -->
                <TextBlock x:ConnectionId='4'
                    Grid.Row="2"
                    x:Name="RemoteStatusText"
                    Text="未连接"
                    FontSize="11"
                    Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                    Padding="0,4,0,0"/>
            </Grid>
        </Grid>
    </Grid>
</Page>

